# Configuración de DESARROLLO con proxy corporativo.
#
# Se carga con `npm run dev`, que aplica primero `.env` (secretos/URLs reales) y
# luego ESTE archivo por encima. Por eso aquí solo va lo específico del proxy:
# no dupliques secretos ni URLs de Cardif/OIDC (viven en `.env`).
#
# Reemplaza host:puerto por el de TU proxy corporativo — el mismo que ves en
# Postman → Settings → Proxy. Si el proxy exige autenticación, usa el formato
# http://usuario:password@host-proxy:puerto.
HTTPS_PROXY=http://j31399:Venus72342406*@sraproxy.us.net.intra:8080
HTTP_PROXY=http://j31399:Venus72342406*@sraproxy.us.net.intra:8080

# Excluye el tráfico local del proxy: así SOLO las llamadas externas del BFF
# (contact-info, Mashery/Cardif) pasan por el proxy; el IdP OIDC (:8080) y
# webview-login (:4300) siguen yendo directo.
NO_PROXY=localhost,127.0.0.1
