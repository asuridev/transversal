      "lastName": "Banco A",
      "credentials": [{ "type": "password", "value": "occidente", "temporary": false }],
      "realmRoles": [],
      "attributes": { "partner": ["banco-occidente"] }
    },
    {
      "username": "asesor-a",
      "enabled": true,
