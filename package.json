{
  "name": "transversal",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:server": "node --test --experimental-strip-types \"src/server/**/*.test.ts\" \"src/shared/**/*.test.ts\" \"src/app/**/*.test.ts\"",
    "db:reset": "node scripts/reset-db.mjs",
    "serve:ssr:transversal": "node dist/transversal/server/server.mjs",
    "serve:ssr": "node dist/transversal/server/server.mjs",
    "start:full": "npm run build && node --env-file=.env dist/transversal/server/server.mjs",
    "start:dev":  "npm run build && node --env-file=.env.dev dist/transversal/server/server.mjs"

  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/platform-server": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@angular/ssr": "^20.3.31",
    "@ngrx/signals": "^20.1.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/angular-query-experimental": "^5.101.2",
    "express": "^5.1.0",
    "openid-client": "^6.8.4",
    "postcss": "^8.5.16",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.3.2",
    "tslib": "^2.3.0",
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.31",
    "@angular/cli": "^20.3.31",
    "@angular/compiler-cli": "^20.3.0",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^22.20.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}
