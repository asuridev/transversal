# BFF — AuthZ/OIDC (006-authz-roles-auditoria). Paridad dev/prod: mismos nombres
# de variable; prod cambia valores (issuer real, secretos del gestor de secretos).

# RH-SSO 7.6 sirve bajo /auth (Keycloak 15.x) — ver dev-idp-infra.contract §4.
OIDC_ISSUER_URL=http://localhost:8080/auth/realms/backoffice
OIDC_CLIENT_ID=backoffice-bff
OIDC_CLIENT_SECRET=backoffice-bff-dev-secret
OIDC_REDIRECT_URI=http://localhost:4000/api/auth/callback

# Login externo (webview-login, 008) — segundo cliente SSO del mismo reino en
# otro dominio. WEBVIEW_LOGIN_ORIGIN admite lista separada por comas (CORS del
# tema); WEBVIEW_LOGIN_URL es el post_logout_redirect_uri del logout de reino
# y el destino de redirección del front cuando no hay sesión.
WEBVIEW_LOGIN_ORIGIN=http://localhost:4300
WEBVIEW_LOGIN_URL=http://localhost:4300

# Sesión sellada AEAD (D2) — 32 bytes en base64.
SESSION_SEAL_KEY=
SESSION_TTL_SECONDS=3600

# Mapeo claim→rol (D5) — config-driven, no hardcode.
ROLE_CLAIM_PATH=realm_access.roles
ROLE_MAP={"platform-admin":"platform-admin","partner-editor":"partner-editor","auditor":"auditor"}

# Contact-info (KYC) — cadena real de Cardif. MASHERY_AUTH_BASEURL sirve los
# pasos 2 y 3 (paramj + access tokens); CUSTOMER_API_BASEURL sirve el paso 1
# (contact_info). El BFF llama a estos hosts server-side (no hay CORS).
MASHERY_AUTH_BASEURL=https://webview-uat.cardif.com.co/mashery-auth-service
CUSTOMER_API_BASEURL=https://api-services-uat.cardifnet.com/CO/UAT

# Proxy corporativo (solo desarrollo). El BFF llama a los hosts externos de
# Cardif server-side; si tu red exige proxy (el mismo que configuras en Postman),
# defínelo aquí. Sin estas vars, el comportamiento no cambia (prod). El fetch de
# Node solo respeta el proxy porque server.ts instala un dispatcher de undici.
# Omite usuario:password@ si el proxy no requiere autenticación.
# NO_PROXY excluye el tráfico local (IdP OIDC :8080, webview-login :4300) para
# que solo las llamadas externas del BFF pasen por el proxy.
# HTTPS_PROXY=http://usuario:password@host-proxy:puerto
# HTTP_PROXY=http://usuario:password@host-proxy:puerto
# NO_PROXY=localhost,127.0.0.1
